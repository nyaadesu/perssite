<style>
  .nerv-window .win-titlebar {
    background: linear-gradient(to right, #8b0000, #cc0000);
  }
  .nerv-terminal {
    background: #000;
    color: #00ccff;
    font-family: "Courier New", monospace;
    font-size: 12px;
    padding: 14px;
    line-height: 1.7;
    border: 1px solid #004466;
  }
  .nerv-terminal .nt-label {
    color: #ff6600;
    font-weight: bold;
    display: inline-block;
    min-width: 180px;
  }
  .nerv-terminal .nt-value { color: #00ffcc; }
  .nerv-terminal .nt-header {
    color: #ff4444;
    font-weight: bold;
    border-bottom: 1px solid #cc0000;
    margin-bottom: 10px;
    padding-bottom: 4px;
    letter-spacing: 2px;
  }
  .nerv-terminal .nt-section {
    color: #ff6600;
    margin: 12px 0 4px;
    font-weight: bold;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .nerv-terminal .nt-bar-track {
    display: inline-block;
    width: 120px;
    background: #003344;
    height: 10px;
    vertical-align: middle;
    border: 1px solid #006688;
  }
  .nerv-terminal .nt-bar-fill {
    display: block;
    height: 100%;
    background: linear-gradient(to right, #006688, #00ccff);
  }
  .nerv-terminal .nt-classified { color: #ff4444; font-weight: bold; letter-spacing: 3px; font-size: 10px; }
  .nerv-terminal .nt-redacted { background: #cc0000; color: #cc0000; padding: 0 2px; user-select: none; }
  .nerv-terminal .nt-blink { animation: nerv-blink 1s step-end infinite; }
  .nerv-terminal .nt-stamp {
    display: inline-block;
    border: 3px solid #cc0000;
    color: #cc0000;
    padding: 2px 8px;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 4px;
    transform: rotate(-12deg);
    opacity: 0.85;
    float: right;
    margin-top: -30px;
    margin-right: 10px;
  }
  .nerv-terminal .nt-report {
    color: #aaddee;
    border-left: 2px solid #004466;
    padding-left: 10px;
    margin: 4px 0;
    font-size: 12px;
    line-height: 1.8;
  }
  .nerv-terminal .nt-report a { color: #00ffcc; }
  @keyframes nerv-blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .seele-window .win-titlebar { background: #000; }
  .seele-window .win-titlebar-title { letter-spacing: 1px; font-size: 11px; }
  .seele-svg { background: #050505; display: block; width: 100%; }

  /* MAGI System Monitor */
  .magi-monitor .win-titlebar { background: linear-gradient(to right, #1a0a00, #4a2000); }
  .magi-panel {
    background: #0a0a0a;
    font-family: "Courier New", monospace;
    font-size: 11px;
    padding: 12px;
    color: #ff8800;
    line-height: 1.6;
    border: 1px solid #331800;
  }
  .magi-panel .magi-header {
    text-align: center;
    color: #ff4400;
    font-weight: bold;
    letter-spacing: 3px;
    font-size: 10px;
    border-bottom: 1px solid #331800;
    padding-bottom: 8px;
    margin-bottom: 10px;
  }
  .magi-nodes {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .magi-node {
    flex: 1;
    border: 1px solid #332200;
    padding: 8px;
    background: #0d0800;
    text-align: center;
  }
  .magi-node-name {
    color: #ff6600;
    font-weight: bold;
    font-size: 10px;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }
  .magi-node-aspect {
    color: #664400;
    font-size: 8px;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .magi-node-status {
    display: inline-block;
    padding: 1px 6px;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
  }
  .magi-node-status.online {
    color: #00ff88;
    border: 1px solid #00ff88;
  }
  .magi-readings {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px 16px;
    margin-bottom: 12px;
    font-size: 11px;
  }
  .magi-readings .mr-label { color: #886600; }
  .magi-readings .mr-value { color: #ffaa00; text-align: right; }
  .magi-readings .mr-warn { color: #ff4400; }
  .magi-log {
    border: 1px solid #221500;
    background: #060400;
    padding: 8px;
    font-size: 10px;
    line-height: 1.8;
    max-height: 140px;
    overflow: hidden;
  }
  .magi-log-line { color: #886600; }
  .magi-log-line .log-time { color: #443300; }
  .magi-log-line .log-ok { color: #00cc66; }
  .magi-log-line .log-warn { color: #ff6600; }
  .magi-log-line .log-crit { color: #ff2200; }
  .magi-pattern {
    display: inline-block;
    padding: 1px 5px;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
    margin-left: 4px;
  }
  .magi-pattern.blue { color: #0088ff; border: 1px solid #0088ff; }
  .magi-pattern.orange { color: #ff6600; border: 1px solid #ff6600; }

  /* Dummy Plug Terminal */
  .dp-window .win-titlebar { background: linear-gradient(to right, #001a00, #003300); }
  .dp-terminal {
    background: #000a00;
    font-family: "Courier New", monospace;
    font-size: 11px;
    padding: 12px;
    color: #00cc44;
    line-height: 1.8;
    border: 1px solid #003300;
  }
  .dp-terminal .dp-header {
    color: #00ff66;
    font-weight: bold;
    letter-spacing: 2px;
    font-size: 10px;
    text-align: center;
    border-bottom: 1px solid #003300;
    padding-bottom: 8px;
    margin-bottom: 10px;
  }
  .dp-line {
    opacity: 0;
    animation: dp-appear 0.1s forwards;
  }
  .dp-line:nth-child(2)  { animation-delay: 0.3s; }
  .dp-line:nth-child(3)  { animation-delay: 0.7s; }
  .dp-line:nth-child(4)  { animation-delay: 1.0s; }
  .dp-line:nth-child(5)  { animation-delay: 1.4s; }
  .dp-line:nth-child(6)  { animation-delay: 1.7s; }
  .dp-line:nth-child(7)  { animation-delay: 2.1s; }
  .dp-line:nth-child(8)  { animation-delay: 2.5s; }
  .dp-line:nth-child(9)  { animation-delay: 2.8s; }
  .dp-line:nth-child(10) { animation-delay: 3.2s; }
  .dp-line:nth-child(11) { animation-delay: 3.5s; }
  .dp-line:nth-child(12) { animation-delay: 3.9s; }
  .dp-line:nth-child(13) { animation-delay: 4.3s; }
  .dp-line:nth-child(14) { animation-delay: 4.7s; }
  .dp-line:nth-child(15) { animation-delay: 5.1s; }
  .dp-line:nth-child(16) { animation-delay: 5.5s; }
  .dp-line:nth-child(17) { animation-delay: 6.0s; }
  .dp-line:nth-child(18) { animation-delay: 6.5s; }
  @keyframes dp-appear { to { opacity: 1; } }
  .dp-ok { color: #00ff66; }
  .dp-warn { color: #ffaa00; }
  .dp-err { color: #ff3333; }
  .dp-sys { color: #007733; }
  .dp-dim { color: #005522; }
  .dp-highlight { color: #00ffaa; font-weight: bold; }
  .dp-cursor {
    display: inline-block;
    width: 7px;
    height: 12px;
    background: #00cc44;
    animation: nerv-blink 0.8s step-end infinite;
    vertical-align: middle;
  }

  /* Side-by-side layout for Tree & Terminal */
  .seele-dp-container {
    display: flex;
    gap: 16px;
    margin: 16px 0 0 0;
    width: 100%;
    max-width: 860px;
    box-sizing: border-box;
  }
  .seele-dp-container .win-window {
    flex: 1 1 auto !important;
    margin-top: 0;
  }
  .seele-dp-container .seele-window {
    min-width: 0;
  }
  .seele-dp-container .dp-window {
    min-width: 0;
    align-self: flex-start;
  }
  @media (max-width: 800px) {
    .seele-dp-container {
      flex-direction: column;
    }
  }

  /* Make NERV window same width as side-by-side container */
  .nerv-window {
    width: 100%;
    margin: 16px 0 0 0;
    box-sizing: border-box;
    max-width: 860px;
  }

  /* Reduce status bar height */
  .nerv-window .status-bar {
    height: 21px;
    padding: 0 4px;
  }
  .dp-window {
    display: flex;
    flex-direction: column;
  }
  .dp-window .dp-terminal {
    flex: 1;
  }
  .dp-window .status-bar {
    height: 21px;
    padding: 0 4px;
    flex-shrink: 0;
  }
</style>

